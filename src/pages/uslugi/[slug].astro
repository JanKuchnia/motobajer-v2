---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import StickyCtaBar from '../../components/StickyCtaBar.astro';
import { services } from '../../data/services';
import { ChevronRight, Calendar, Phone, ArrowRight } from 'lucide-astro';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const icons: Record<string, string> = {
  wrench: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.654-4.654m5.896-3.046.206-.2A9.5 9.5 0 0 0 7.5 3.5c-.977 0-1.915.145-2.796.413m5.716 9.257L7.5 7.5m6.136 5.67A9.458 9.458 0 0 1 7.5 14.5c-.977 0-1.915-.145-2.796-.413"/>`,
  cpu: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z"/>`,
  disc: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z"/>`,
  snowflake: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 12h18M5.636 5.636l12.728 12.728M18.364 5.636 5.636 18.364"/><circle cx="12" cy="12" r="2.25" fill="currentColor" stroke="none"/>`,
  bolt: `<path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/>`,
  wheel: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3c4.97 0 9 4.03 9 9s-4.03 9-9 9-9-4.03-9-9 4.03-9 9-9Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v3.75m0 0 2.25 2.25M12 12l-2.25 2.25M12 12l2.25-2.25M12 12l-2.25-2.25"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>`,
};

const pageTitle = `${service.title} — MOTOBAJER Myślenice`;
const pageDesc = `${service.description} Warsztat MOTOBAJER w Myślenicach. EuroWarsztat. Zadzwoń: 609 845 865.`;
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Nav />
  <main id="main-content">

    <!-- Hero strip -->
    <div class="bg-navy pt-32 pb-16 px-4 sm:px-6">
      <div class="max-w-6xl mx-auto">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm" style="color: oklch(65% 0.04 265);">
            <li><a href="/" class="hover:text-white transition-colors">Strona główna</a></li>
            <li aria-hidden="true"><ChevronRight class="w-3.5 h-3.5 inline" /></li>
            <li><a href="/#uslugi" class="hover:text-white transition-colors">Usługi</a></li>
            <li aria-hidden="true"><ChevronRight class="w-3.5 h-3.5 inline" /></li>
            <li class="text-white font-medium" aria-current="page">{service.title}</li>
          </ol>
        </nav>

        <div class="flex items-center gap-5 mb-4">
          <div
            class="w-14 h-14 rounded-lg flex items-center justify-center shrink-0"
            style="background: var(--color-accent);"
          >
            <svg
              class="w-7 h-7 text-white"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              viewBox="0 0 24 24"
              aria-hidden="true"
              set:html={icons[service.icon]}
            />
          </div>
          <h1
            class="text-white font-bold leading-tight"
            style="font-family: var(--font-display); font-size: clamp(2.4rem, 5vw, 3.8rem); letter-spacing: -0.02em;"
          >
            {service.title}
          </h1>
        </div>
        <p class="max-w-2xl text-lg leading-relaxed" style="color: oklch(75% 0.04 265);">
          {service.description}
        </p>
      </div>
    </div>

    <!-- Main content -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 grid lg:grid-cols-3 gap-12 lg:gap-16">

      <!-- Left: details -->
      <div class="lg:col-span-2 space-y-12">

        <!-- Long description -->
        <section>
          <h2
            class="reveal font-bold mb-4 text-ink"
            style="font-family: var(--font-display); font-size: clamp(1.5rem, 2.5vw, 2rem);"
          >
            O usłudze
          </h2>
          <p class="reveal text-base leading-relaxed" style="color: var(--color-ink-muted);">
            {service.longDescription}
          </p>
        </section>

        <!-- What's included -->
        <section>
          <h2
            class="reveal font-bold mb-5 text-ink"
            style="font-family: var(--font-display); font-size: clamp(1.5rem, 2.5vw, 2rem);"
          >
            Co obejmuje usługa
          </h2>
          <ul class="reveal space-y-3">
            {service.includes.map((item) => (
              <li class="flex items-start gap-3">
                <span
                  class="mt-1 w-5 h-5 rounded-full flex items-center justify-center shrink-0"
                  style="background: var(--color-accent);"
                  aria-hidden="true"
                >
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                  </svg>
                </span>
                <span class="text-base" style="color: var(--color-ink-muted);">{item}</span>
              </li>
            ))}
          </ul>
        </section>

        <!-- Mobile-only CTA (sidebar is below fold on mobile) -->
        <div class="reveal lg:hidden rounded-xl bg-navy p-5 flex flex-col sm:flex-row gap-3">
          <a
            href="/#rezerwacja"
            class="flex-1 inline-flex items-center justify-center gap-2 py-3 rounded-md font-semibold text-navy btn-lift text-sm"
            style="background: #fff;"
          >
            <Calendar class="w-4 h-4 shrink-0" aria-hidden="true" />
            Zarezerwuj wizytę
          </a>
          <a
            href="tel:+48609845865"
            class="flex-1 inline-flex items-center justify-center gap-2 py-3 rounded-md font-semibold text-white text-sm transition-colors"
            style="background: var(--color-accent);"
          >
            <Phone class="w-4 h-4 shrink-0" aria-hidden="true" />
            Zadzwoń: 609 845 865
          </a>
        </div>

        <!-- FAQ -->
        {service.faq.length > 0 && (
          <section>
            <h2
              class="reveal font-bold mb-6 text-ink"
              style="font-family: var(--font-display); font-size: clamp(1.5rem, 2.5vw, 2rem);"
            >
              Pytania i odpowiedzi
            </h2>
            <div class="reveal border-t" style="border-color: oklch(88% 0.01 265);">
              {service.faq.map((item, i) => (
                <details
                  class="faq-item border-b"
                  style={`border-color: oklch(88% 0.01 265);`}
                >
                  <summary class="faq-summary flex items-center justify-between gap-4 py-5 cursor-pointer list-none">
                    <span class="font-semibold text-base" style="color: var(--color-ink);">{item.q}</span>
                    <span
                      class="faq-icon shrink-0 w-8 h-8 rounded-full flex items-center justify-center transition-colors duration-150"
                      style="background: var(--color-surface-1);"
                      aria-hidden="true"
                    >
                      <svg class="faq-plus w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                      </svg>
                      <svg class="faq-minus w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15"/>
                      </svg>
                    </span>
                  </summary>
                  <div class="faq-body pb-5 pr-12">
                    <p class="text-base leading-relaxed" style="color: var(--color-ink-muted);">{item.a}</p>
                  </div>
                </details>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Right: sidebar -->
      <aside class="space-y-6">

        <!-- Duration card -->
        <div
          class="reveal rounded-xl p-6"
          style="background: var(--color-surface-1); border: 1px solid oklch(90% 0.008 265);"
        >
          <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--color-ink-muted);">
            Czas realizacji
          </p>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--color-accent);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
            <p class="text-sm font-medium" style="color: var(--color-ink);">{service.duration}</p>
          </div>
        </div>

        <!-- CTA card -->
        <div
          class="reveal rounded-xl p-6 bg-navy"
        >
          <h3
            class="font-bold text-white mb-2"
            style="font-family: var(--font-display); font-size: 1.35rem;"
          >
            Gotowy na wizytę?
          </h3>
          <p class="text-sm mb-5" style="color: oklch(72% 0.04 265);">
            Umów się przez formularz lub zadzwoń bezpośrednio.
          </p>
          <a
            href="/#rezerwacja"
            class="flex items-center justify-center gap-2 py-3 rounded-md font-semibold text-navy btn-lift mb-3"
            style="background: #fff; font-size: 0.95rem;"
            onmouseover="this.style.background='oklch(96% 0.01 265)'"
            onmouseout="this.style.background='#fff'"
          >
            <Calendar class="w-4 h-4 shrink-0" aria-hidden="true" />
            Zarezerwuj wizytę
          </a>
          <a
            href="tel:+48609845865"
            class="flex items-center justify-center gap-2 py-3 rounded-md text-sm font-semibold text-white transition-colors"
            style="background: var(--color-accent);"
            onmouseover="this.style.background='var(--color-accent-hover)'"
            onmouseout="this.style.background='var(--color-accent)'"
          >
            <Phone class="w-4 h-4 shrink-0" aria-hidden="true" />
            Zadzwoń: 609 845 865
          </a>
        </div>

        <!-- Other services -->
        <div
          class="reveal rounded-xl p-6"
          style="border: 1px solid oklch(90% 0.008 265);"
        >
          <h3
            class="font-bold text-ink mb-4"
            style="font-family: var(--font-display); font-size: 1.1rem;"
          >
            Inne usługi
          </h3>
          <ul class="space-y-2">
            {services.filter((s) => s.slug !== service.slug).map((s) => (
              <li>
                <a
                  href={`/uslugi/${s.slug}`}
                  class="inline-flex items-center gap-1.5 text-sm font-medium transition-colors hover:text-navy"
                  style="color: var(--color-ink-muted);"
                >
                  <ArrowRight class="w-3 h-3 shrink-0" aria-hidden="true" />
                  {s.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </aside>
    </div>

  </main>
  <Footer />
  <StickyCtaBar />
</BaseLayout>

<style>
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-item[open] .faq-plus { display: none; }
  .faq-item[open] .faq-minus { display: block; }
  .faq-item[open] .faq-icon { background: var(--color-navy); color: #fff; }
  .faq-item[open] .faq-icon svg { stroke: #fff; }
  .faq-summary:hover span:first-child { color: var(--color-navy); }
  .faq-body {
    animation: faqOpen 0.2s var(--ease-quart) forwards;
  }
  @keyframes faqOpen {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
