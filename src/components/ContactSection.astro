---
import { Send } from 'lucide-astro';

const FORMSPREE_ID = import.meta.env.PUBLIC_FORMSPREE_ID ?? '';
const formAction = FORMSPREE_ID
  ? `https://formspree.io/f/${FORMSPREE_ID}`
  : 'mailto:motobajer@eurowarsztat.pl';

const hours = [
  { day: 'Poniedziałek – Piątek', time: '08:00 – 17:00', open: true },
  { day: 'Sobota', time: '08:00 – 13:00', open: true },
  { day: 'Niedziela', time: 'Zamknięte', open: false },
];

const timeSlots: string[] = [];
for (let h = 8; h <= 16; h++) {
  timeSlots.push(`${String(h).padStart(2, '0')}:00`);
  if (h < 16) timeSlots.push(`${String(h).padStart(2, '0')}:30`);
}

const serviceOptions = [
  'Mechanika ogólna',
  'Diagnostyka komputerowa',
  'Hamulce i zawieszenie',
  'Klimatyzacja',
  'Elektryka pojazdowa',
  'Wulkanizacja',
  'Inne',
];
---

<section id="kontakt" class="section-py below-fold bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">

      <!-- LEFT: booking form -->
      <div class="lg:col-span-3" id="rezerwacja">
        <h2
          class="reveal section-heading text-ink mb-2"
          style="font-family: var(--font-display);"
        >
          Zarezerwuj wizytę
        </h2>
        <p class="reveal text-base leading-relaxed mb-8" style="color: var(--color-ink-muted);">
          Wypełnij formularz, a oddzwonimy w ciągu godziny, by potwierdzić termin.
        </p>

        <!-- Success banner -->
        <div
          id="contact-success"
          class="hidden mb-6 px-5 py-4 rounded-lg text-sm font-medium"
          style="background: oklch(95% 0.05 145); color: oklch(30% 0.1 145); border: 1px solid oklch(85% 0.08 145);"
          role="alert"
        >
          Dziękujemy! Skontaktujemy się z Tobą wkrótce, by potwierdzić termin.
        </div>

        <form
          id="contact-form"
          action={formAction}
          method="POST"
          class="reveal space-y-5"
          novalidate
        >
          <input type="hidden" name="_subject" value="Rezerwacja wizyty — MOTOBAJER" />
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="lf-label" for="name">Imię i nazwisko *</label>
              <input
                id="name" name="name" type="text" class="lf-input"
                placeholder="Jan Kowalski"
                required minlength="2" maxlength="100"
                autocomplete="name"
                aria-describedby="name-error"
              />
              <p id="name-error" class="lf-error" role="alert" aria-live="polite"></p>
            </div>
            <div>
              <label class="lf-label" for="phone">Telefon *</label>
              <input
                id="phone" name="phone" type="tel" class="lf-input"
                placeholder="500 100 200"
                required maxlength="20"
                autocomplete="tel"
                aria-describedby="phone-error"
              />
              <p id="phone-error" class="lf-error" role="alert" aria-live="polite"></p>
            </div>
          </div>

          <div>
            <label class="lf-label" for="email">Adres e-mail</label>
            <input
              id="email" name="email" type="email" class="lf-input"
              placeholder="jan@example.pl"
              maxlength="150"
              autocomplete="email"
              aria-describedby="email-error"
            />
            <p id="email-error" class="lf-error" role="alert" aria-live="polite"></p>
          </div>

          <div>
            <label class="lf-label" for="service">Rodzaj usługi *</label>
            <select
              id="service" name="service" class="lf-input"
              required
              aria-describedby="service-error"
            >
              <option value="" disabled selected>Wybierz usługę...</option>
              {serviceOptions.map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
            <p id="service-error" class="lf-error" role="alert" aria-live="polite"></p>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="lf-label" for="date">Preferowana data *</label>
              <input
                id="date" name="date" type="date" class="lf-input"
                required
                aria-describedby="date-error"
              />
              <p id="date-error" class="lf-error" role="alert" aria-live="polite"></p>
            </div>
            <div>
              <label class="lf-label" for="time">Preferowana godzina</label>
              <select id="time" name="time" class="lf-input">
                <option value="">Dowolna</option>
                {timeSlots.map((slot) => (
                  <option value={slot}>{slot}</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label class="lf-label" for="notes">Dodatkowe informacje</label>
            <textarea
              id="notes" name="notes" class="lf-input resize-none"
              rows="3" maxlength="500"
              placeholder="Opisz krótko problem lub marka/model pojazdu..."
            ></textarea>
          </div>

          <button
            id="contact-submit"
            type="submit"
            class="w-full inline-flex items-center justify-center gap-2 py-3.5 rounded-md font-semibold text-white transition-colors duration-150 disabled:opacity-60 disabled:cursor-not-allowed focus-ring-white hover-accent"
            style="font-family: var(--font-body); font-size: 1rem; background: var(--color-accent);"
          >
            <Send class="w-4 h-4 shrink-0" aria-hidden="true" />
            Wyślij zapytanie
          </button>

          <p class="text-xs text-center" style="color: var(--color-ink-muted);">
            Pola oznaczone * są wymagane. Odpowiadamy w ciągu 1 godziny w godzinach pracy.
          </p>

          <noscript>
            <p class="text-sm text-center" style="color: var(--color-ink-muted);">
              Aby zarezerwować wizytę, zadzwoń pod numer
              <a href="tel:+48609845865" class="underline text-navy">609 845 865</a>.
            </p>
          </noscript>
        </form>
      </div>

      <!-- RIGHT: contact info -->
      <div class="lg:col-span-2">
        <!-- Divider on mobile -->
        <hr class="lg:hidden mb-10" style="border-color: oklch(90% 0.005 265);" />

        <h3
          class="reveal text-ink mb-8"
          style="font-family: var(--font-display); font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; line-height: 1.1;"
        >
          Kontakt
        </h3>

        <!-- Hours -->
        <div class="reveal mb-8">
          <h3
            class="text-sm font-semibold mb-4"
            style="color: var(--color-ink-muted);"
          >
            Godziny otwarcia
          </h3>
          <table class="w-full text-sm" aria-label="Godziny otwarcia serwisu">
            <tbody>
              {hours.map((row) => (
                <tr class="border-b last:border-b-0" style="border-color: oklch(92% 0.005 265);">
                  <td class="py-2.5 pr-4 font-medium" style="color: var(--color-ink);">{row.day}</td>
                  <td
                    class="py-2.5 text-right font-semibold"
                    style={`color: ${row.open ? 'var(--color-navy)' : 'var(--color-ink-muted)'};`}
                  >
                    {row.time}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Contact details -->
        <div class="reveal" style="transition-delay: 80ms;">
          <h3
            class="text-sm font-semibold mb-4"
            style="color: var(--color-ink-muted);"
          >
            Dane kontaktowe
          </h3>

          <ul class="space-y-4 text-sm">
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5" style="background: var(--color-surface-1);">
                <svg class="w-4 h-4 text-navy" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold mb-1" style="color: var(--color-ink-muted);">Telefon</p>
                <a href="tel:+48609845865" class="font-medium text-navy hover:text-navy-light transition-colors block">609 845 865</a>
                <a href="tel:+48122742306" class="font-medium text-navy hover:text-navy-light transition-colors block mt-0.5">(12) 274 23 06</a>
              </div>
            </li>

            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5" style="background: var(--color-surface-1);">
                <svg class="w-4 h-4 text-navy" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold mb-1" style="color: var(--color-ink-muted);">E-mail</p>
                <a href="mailto:motobajer@eurowarsztat.pl" class="font-medium text-navy hover:text-navy-light transition-colors">motobajer@eurowarsztat.pl</a>
              </div>
            </li>

            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5" style="background: var(--color-surface-1);">
                <svg class="w-4 h-4 text-navy" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold mb-1" style="color: var(--color-ink-muted);">Adresy</p>
                <p class="font-medium" style="color: var(--color-ink);">Warsztat: ul. Drogowców 7, 32-400 Myślenice</p>
                <p class="font-medium mt-0.5" style="color: var(--color-ink);">Sklep: ul. Armii Krajowej 2, 32-400 Myślenice</p>
              </div>
            </li>

            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5" style="background: var(--color-surface-1);">
                <svg class="w-4 h-4 text-navy" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold mb-1" style="color: var(--color-ink-muted);">Sieć</p>
                <p class="font-medium" style="color: var(--color-ink);">EuroWarsztat (Groupauto)</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lf-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
    color: var(--color-ink);
  }

  .lf-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    background: #fff;
    border: 1px solid oklch(82% 0.01 265);
    border-radius: 6px;
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    transition: border-color 0.15s, box-shadow 0.15s;
    appearance: none;
  }

  .lf-input::placeholder {
    color: oklch(50% 0.02 265);
  }

  .lf-input:focus {
    outline: none;
    border-color: var(--color-navy);
    box-shadow: 0 0 0 3px oklch(35% 0.14 265 / 0.12);
  }

  .lf-input option {
    color: var(--color-ink);
  }

  .lf-error {
    margin-top: 0.3rem;
    font-size: 0.8125rem;
    color: oklch(48% 0.18 25);
    display: none;
  }

  .lf-input[aria-invalid="true"] {
    border-color: oklch(58% 0.18 25);
  }

  .lf-input[aria-invalid="true"]:focus {
    border-color: oklch(58% 0.18 25);
    box-shadow: 0 0 0 3px oklch(58% 0.18 25 / 0.15);
  }
</style>

<script>
  const dateInput = document.getElementById('date') as HTMLInputElement | null;
  if (dateInput) {
    dateInput.min = new Date().toISOString().split('T')[0];
  }

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

  function showError(inputId: string, message: string) {
    const errorEl = document.getElementById(`${inputId}-error`);
    const inputEl = form?.querySelector<HTMLElement>(`[name="${inputId}"]`);
    if (errorEl) { errorEl.textContent = message; errorEl.style.display = 'block'; }
    if (inputEl) inputEl.setAttribute('aria-invalid', 'true');
  }

  function clearError(inputId: string) {
    const errorEl = document.getElementById(`${inputId}-error`);
    const inputEl = form?.querySelector<HTMLElement>(`[name="${inputId}"]`);
    if (errorEl) { errorEl.textContent = ''; errorEl.style.display = 'none'; }
    if (inputEl) inputEl.removeAttribute('aria-invalid');
  }

  ['name', 'phone', 'email', 'service', 'date'].forEach((id) => {
    const el = form?.querySelector(`[name="${id}"]`);
    el?.addEventListener('input', () => clearError(id));
    el?.addEventListener('change', () => clearError(id));
  });

  form?.addEventListener('submit', async (e) => {
    let valid = true;

    const name = (form.querySelector<HTMLInputElement>('[name="name"]'))?.value.trim();
    const phone = (form.querySelector<HTMLInputElement>('[name="phone"]'))?.value.trim();
    const email = (form.querySelector<HTMLInputElement>('[name="email"]'))?.value.trim();
    const service = (form.querySelector<HTMLSelectElement>('[name="service"]'))?.value;
    const date = (form.querySelector<HTMLInputElement>('[name="date"]'))?.value;

    if (!name || name.length < 2) {
      showError('name', 'Podaj imię i nazwisko (min. 2 znaki).');
      valid = false;
    }
    if (!phone) {
      showError('phone', 'Podaj numer telefonu.');
      valid = false;
    }
    if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('email', 'Podaj poprawny adres e-mail.');
      valid = false;
    }
    if (!service) {
      showError('service', 'Wybierz rodzaj usługi.');
      valid = false;
    }
    if (!date) {
      showError('date', 'Wybierz preferowaną datę.');
      valid = false;
    }

    if (!valid) {
      e.preventDefault();
      const firstInvalid = form.querySelector('[aria-invalid="true"]') as HTMLElement | null;
      firstInvalid?.focus();
      return;
    }

    if (!form.action.startsWith('mailto:')) {
      e.preventDefault();
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Wysyłanie…';
      }
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          const banner = document.getElementById('contact-success');
          banner?.classList.remove('hidden');
          banner?.classList.add('booking-success-enter');
          form.reset();
          banner?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          alert('Wystąpił błąd. Proszę zadzwoń: 609 845 865');
        }
      } catch {
        alert('Brak połączenia. Proszę zadzwoń: 609 845 865');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Wyślij zapytanie';
        }
      }
    } else {
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Otwieranie poczty…';
        setTimeout(() => {
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Wyślij zapytanie'; }
        }, 4000);
      }
    }
  });
</script>
