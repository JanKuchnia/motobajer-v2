---
import { Calendar, Phone, Mail, MapPin } from 'lucide-astro';

const hours = [
  { day: 'Poniedziałek – Piątek', time: '08:00 – 17:00', open: true },
  { day: 'Sobota', time: '08:00 – 13:00', open: true },
  { day: 'Niedziela', time: 'Zamknięte', open: false },
];
---

<section id="kontakt" class="section-py bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <h2
      class="reveal reveal-clip section-heading text-ink mb-12"
      style="font-family: var(--font-display);"
    >
      Kontakt
    </h2>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">

      <!-- Left: hours + booking CTA -->
      <div class="reveal">
        <h3
          class="text-xs font-semibold uppercase tracking-widest mb-4"
          style="color: var(--color-ink-muted);"
        >
          Godziny otwarcia
        </h3>

        <table class="w-full text-sm mb-8" aria-label="Godziny otwarcia serwisu">
          <tbody>
            {hours.map((row) => (
              <tr class="border-b last:border-b-0" style="border-color: oklch(92% 0.005 265);">
                <td class="py-2.5 pr-4 font-medium" style="color: var(--color-ink);">{row.day}</td>
                <td
                  class="py-2.5 text-right font-semibold"
                  style={`color: ${row.open ? 'var(--color-navy)' : 'var(--color-ink-muted)'};`}
                >
                  {row.time}
                </td>
              </tr>
            ))}
          </tbody>
        </table>

        <a
          href="#rezerwacja"
          class="btn-lift inline-flex items-center gap-2 px-6 py-3 rounded-md text-sm font-semibold text-white"
          style="background: var(--color-accent);"
          onmouseover="this.style.background='var(--color-accent-hover)'"
          onmouseout="this.style.background='var(--color-accent)'"
        >
          <Calendar class="w-4 h-4 shrink-0" aria-hidden="true" />
          Zarezerwuj wizytę online
        </a>
      </div>

      <!-- Right: contact details -->
      <div class="reveal" style="transition-delay: 80ms;">
        <h3
          class="text-xs font-semibold uppercase tracking-widest mb-6"
          style="color: var(--color-ink-muted);"
        >
          Dane kontaktowe
        </h3>

        <ul class="space-y-5 text-sm">
          <li class="flex items-start gap-3">
            <div
              class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5"
              style="background: var(--color-surface-1);"
            >
              <Phone class="w-4 h-4" style="color: var(--color-navy);" aria-hidden="true" />
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide mb-1" style="color: var(--color-ink-muted);">Telefon</p>
              <a href="tel:+48609845865" class="font-medium block transition-colors" style="color: var(--color-navy);"
                onmouseover="this.style.color='var(--color-navy-light)'"
                onmouseout="this.style.color='var(--color-navy)'"
              >609 845 865</a>
              <a href="tel:+48122742306" class="font-medium block mt-0.5 transition-colors" style="color: var(--color-navy);"
                onmouseover="this.style.color='var(--color-navy-light)'"
                onmouseout="this.style.color='var(--color-navy)'"
              >(12) 274 23 06</a>
            </div>
          </li>

          <li class="flex items-start gap-3">
            <div
              class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5"
              style="background: var(--color-surface-1);"
            >
              <Mail class="w-4 h-4" style="color: var(--color-navy);" aria-hidden="true" />
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide mb-1" style="color: var(--color-ink-muted);">E-mail</p>
              <a href="mailto:motobajer@eurowarsztat.pl" class="font-medium transition-colors" style="color: var(--color-navy);"
                onmouseover="this.style.color='var(--color-navy-light)'"
                onmouseout="this.style.color='var(--color-navy)'"
              >motobajer@eurowarsztat.pl</a>
            </div>
          </li>

          <li class="flex items-start gap-3">
            <div
              class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5"
              style="background: var(--color-surface-1);"
            >
              <MapPin class="w-4 h-4" style="color: var(--color-navy);" aria-hidden="true" />
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide mb-1" style="color: var(--color-ink-muted);">Adresy</p>
              <p class="font-medium" style="color: var(--color-ink);">Warsztat: ul. Drogowców 7, 32-400 Myślenice</p>
              <p class="font-medium mt-1" style="color: var(--color-ink);">Sklep: ul. Armii Krajowej 2, 32-400 Myślenice</p>
            </div>
          </li>
        </ul>
      </div>

    </div>
  </div>
</section>
