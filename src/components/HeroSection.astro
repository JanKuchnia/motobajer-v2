---
import { Calendar, Phone } from 'lucide-astro';
---

<section
  id="hero"
  class="relative flex items-center overflow-hidden"
  style="min-height: 78vh; padding-top: 5rem; background-color: var(--color-navy);"
>
  <!-- Background photo -->
  <picture aria-hidden="true" class="absolute inset-0 block">
    <source
      type="image/webp"
      srcset="/images/hero-bg-1024.webp 1024w, /images/hero-bg.webp 1920w"
      sizes="100vw"
    />
    <img
      src="/images/hero-bg.jpg"
      alt=""
      class="w-full h-full object-cover"
      style="object-position: center 40%;"
      fetchpriority="high"
      decoding="async"
      width="1920"
      height="1080"
    />
  </picture>

  <!-- Dark navy overlay -->
  <div
    aria-hidden="true"
    class="absolute inset-0"
    style="background: linear-gradient(105deg, oklch(18% 0.10 265 / 0.88) 0%, oklch(24% 0.12 265 / 0.72) 60%, oklch(18% 0.10 265 / 0.55) 100%);"
  ></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 w-full py-14 md:py-20">
    <div class="max-w-2xl">
      <!-- Accent rule + location tag -->
      <div class="hero-fade-up flex items-center gap-4 mb-7" style="animation-delay: 0.05s;">
        <div aria-hidden="true" class="hero-accent-rule" style="width: 3rem; height: 3px; background: var(--color-accent); flex-shrink: 0;"></div>
        <span class="text-sm font-semibold" style="color: oklch(76% 0.06 265); font-family: var(--font-display);">
          Sieć EuroWarsztat · Myślenice
        </span>
      </div>

      <!-- Heading -->
      <h1
        class="hero-heading font-bold mb-6 text-white"
        style="font-family: var(--font-display); font-size: clamp(2.5rem, 7vw, 5.5rem); line-height: 1.05; letter-spacing: -0.02em; text-wrap: balance;"
      >
        Warsztat samochodowy w Myślenicach,
        <span style="color: var(--color-accent-light);">któremu możesz zaufać</span>
      </h1>

      <!-- Subheadline -->
      <p
        class="hero-fade-up text-lg md:text-xl leading-relaxed mb-10 max-w-xl"
        style="color: oklch(82% 0.03 265); animation-delay: 0.32s;"
      >
        Pełen serwis mechaniczny, diagnostyka komputerowa i sklep z częściami.
        Dwa punkty w centrum Myślenic, działamy od 2008 roku.
      </p>

      <!-- CTAs -->
      <div class="hero-fade-up flex flex-col sm:flex-row gap-3 mb-12" style="animation-delay: 0.44s;">
        <a
          href="#rezerwacja"
          class="btn-lift inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-md font-semibold text-white"
          style="background: var(--color-accent); font-family: var(--font-body);"
          onmouseover="this.style.background='var(--color-accent-hover)'"
          onmouseout="this.style.background='var(--color-accent)'"
        >
          <Calendar class="w-5 h-5 shrink-0" aria-hidden="true" />
          Zarezerwuj wizytę
        </a>
        <a
          href="tel:+48609845865"
          class="btn-lift inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-md font-semibold text-white border hover:bg-white/10"
          style="border-color: oklch(100% 0 0 / 0.35); font-family: var(--font-body);"
        >
          <Phone class="w-5 h-5 shrink-0" aria-hidden="true" />
          609 845 865
        </a>
      </div>

      <!-- Trust indicators -->
      <div
        class="hero-fade-up flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium"
        style="color: oklch(80% 0.04 265); animation-delay: 0.56s;"
      >
        <span>Myślenice od 2008</span>
        <span style="color: oklch(55% 0.05 265);">·</span>
        <span>Sieć EuroWarsztat</span>
        <span style="color: oklch(55% 0.05 265);">·</span>
        <span>Wszystkie opinie 5★</span>
        <span style="color: oklch(55% 0.05 265);">·</span>
        <span>Dwa punkty obsługi</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    aria-hidden="true"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1"
  >
    <span class="text-xs text-white tracking-widest uppercase opacity-40" style="font-size: 0.65rem;">Przewiń</span>
    <svg class="w-4 h-4 text-white scroll-pulse" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
