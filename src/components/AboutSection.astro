---
import { Wrench, Phone } from 'lucide-astro';

const stats = [
  { value: '18', unit: 'lat', label: 'doświadczenia' },
  { value: '2', unit: 'punkty', label: 'obsługi w Myślenicach' },
  { value: '5.0', unit: '★', label: 'średnia ocen Google' },
  { value: 'Euro', unit: 'Warsztat', label: 'sieć Groupauto' },
];
---

<section id="o-nas" class="section-py bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">

      <!-- Left: text -->
      <div>
        <h2
          class="reveal section-heading text-ink mb-6"
          style="font-family: var(--font-display);"
        >
          Warsztat z tradycją, obsługa bez kompromisów
        </h2>

        <div class="reveal space-y-4 text-base leading-relaxed" style="color: var(--color-ink-muted);">
          <p>
            MOTOBAJER to rodzinny serwis samochodowy prowadzony przez
            <strong style="color: var(--color-ink); font-weight: 600;">Stanisława Bajera</strong>
            od 2008 roku. Przez ponad 18 lat zbudowaliśmy reputację warsztatu,
            do którego klienci wracają — i polecają go innym.
          </p>
          <p>
            Działamy w dwóch punktach w Myślenicach: centrum serwisowe
            przy ul. Drogowców 7 oraz sklep z częściami zamiennymi przy ul. Armii
            Krajowej 2. Dzięki temu obsługujemy kompleksowo — od naprawy
            po zakup części.
          </p>
          <p>
            Jako autoryzowany punkt sieci
            <strong style="color: var(--color-ink); font-weight: 600;">EuroWarsztat (Groupauto)</strong>
            mamy dostęp do zaawansowanego wsparcia technicznego, szkoleń
            i oryginalnych części w konkurencyjnych cenach.
          </p>
        </div>

        <div class="reveal mt-8 flex flex-wrap gap-3">
          <a
            href="#uslugi"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-semibold text-white bg-navy hover:bg-navy-light transition-colors"
          >
            <Wrench class="w-4 h-4 shrink-0" aria-hidden="true" />
            Nasze usługi
          </a>
          <a
            href="tel:+48609845865"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-semibold border transition-colors hover-surface-border"
            style="color: var(--color-navy); border-color: oklch(82% 0.05 265);"
          >
            <Phone class="w-4 h-4 shrink-0" aria-hidden="true" />
            Zadzwoń do nas
          </a>
        </div>
      </div>

      <!-- Right: trust stats -->
      <div class="reveal grid grid-cols-2 gap-x-6 gap-y-8 sm:gap-x-10 sm:gap-y-10">
        {stats.map((stat, i) => (
          <div style={`transition-delay: ${i * 60}ms;`}>
            <p
              class="font-bold leading-none"
              style={`font-family: var(--font-display); font-size: clamp(2rem, 3.5vw, 2.8rem); color: var(--color-navy);`}
            >
              {stat.value}<span style="font-size: 0.5em; margin-left: 0.12em; color: var(--color-accent);">{stat.unit}</span>
            </p>
            <p class="text-sm mt-2" style="color: var(--color-ink-muted);">{stat.label}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

