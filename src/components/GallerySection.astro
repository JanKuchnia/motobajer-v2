---
// Gallery items — add real photos to /public/images/gallery/ and restore the
// masonry grid when photos are available. Each item needs a `src` field added:
// { src: '/images/gallery/warsztat-01.jpg', alt: '...', aspect: 'tall' }
const items = [
  { alt: 'Warsztat MOTOBAJER — widok ogólny warsztatu', aspect: 'tall' },
  { alt: 'Warsztat MOTOBAJER — stanowisko diagnostyczne', aspect: 'wide' },
  { alt: 'Warsztat MOTOBAJER — podnośnik samochodowy', aspect: 'square' },
  { alt: 'Warsztat MOTOBAJER — sklep z częściami', aspect: 'tall' },
  { alt: 'Warsztat MOTOBAJER — wymiana opon', aspect: 'wide' },
  { alt: 'Warsztat MOTOBAJER — narzędzia mechaniczne', aspect: 'square' },
  { alt: 'Warsztat MOTOBAJER — obsługa klienta', aspect: 'wide' },
  { alt: 'Warsztat MOTOBAJER — fasada budynku', aspect: 'square' },
];
---

<section id="galeria" class="section-py below-fold bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="mb-10">
      <h2 class="reveal reveal-clip section-heading text-ink" style="font-family: var(--font-display);">
        Nasz warsztat
      </h2>
      <p class="reveal mt-2 text-sm" style="color: var(--color-ink-muted);">
        Nowoczesne wyposażenie i profesjonalne środowisko pracy.
      </p>
    </div>

    <!-- Editorial placeholder — remove this block and restore the masonry grid below when real photos arrive -->
    <div
      class="reveal rounded-xl overflow-hidden flex flex-col sm:flex-row items-center gap-8 px-8 py-12 sm:py-16"
      style="background: var(--color-navy);"
    >
      <div class="shrink-0">
        <svg class="w-16 h-16 opacity-40" fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24" aria-hidden="true" style="color: #fff;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75 7.5 10.5l3 3 4.5-6 6 7.5M21 19.5H3a.75.75 0 0 1-.75-.75V5.25A.75.75 0 0 1 3 4.5h18a.75.75 0 0 1 .75.75v13.5a.75.75 0 0 1-.75.75Z"/>
        </svg>
      </div>
      <div class="text-center sm:text-left">
        <p class="font-bold text-white mb-2" style="font-family: var(--font-display); font-size: clamp(1.4rem, 3vw, 2rem);">
          Zdjęcia warsztatu wkrótce
        </p>
        <p class="text-sm mb-6" style="color: oklch(72% 0.04 265);">
          Zapraszamy do odwiedzin — dwa punkty obsługi w centrum Myślenic.
        </p>
        <a
          href="#lokalizacje"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-semibold btn-lift hover-accent"
          style="background: var(--color-accent); color: #fff; font-family: var(--font-body);"
        >
          Zobacz jak do nas dojechać
        </a>
      </div>
    </div>

    <!--
      Masonry grid — restore when real photos are available.
      Place photos in /public/images/gallery/ and add src to each item above.

    <style>
      @media (min-width: 640px) { .gallery-grid { columns: 3 !important; } }
      @media (min-width: 1024px) { .gallery-grid { columns: 4 !important; } }
    </style>

    <div class="gallery-grid" style="columns: 2; column-gap: 1rem;">
      {items.map((item, i) => (
        <figure
          class="gallery-item reveal mb-4 rounded-lg overflow-hidden break-inside-avoid"
          data-stagger={i * 60}
          style="display: inline-block; width: 100%;"
        >
          <img
            src={item.src}
            alt={item.alt}
            loading="lazy"
            class="w-full object-cover block"
            style="height: ..."
            width="400"
            height="300"
          />
        </figure>
      ))}
    </div>
    -->

  </div>
</section>
