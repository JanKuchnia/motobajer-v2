---
const items = [
  {
    src: 'https://images.unsplash.com/photo-1487754180451-c456f719a1fc?auto=format&fit=crop&w=800&q=80',
    alt: 'Warsztat MOTOBAJER — widok ogólny warsztatu',
    aspect: 'tall',
    width: 800,
    height: 1067,
  },
  {
    src: 'https://images.unsplash.com/photo-1530046339160-ce3e530c7d2f?auto=format&fit=crop&w=800&q=80',
    alt: 'Warsztat MOTOBAJER — stanowisko diagnostyczne',
    aspect: 'wide',
    width: 800,
    height: 534,
  },
  {
    src: 'https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?auto=format&fit=crop&w=800&q=80',
    alt: 'Warsztat MOTOBAJER — podnośnik samochodowy',
    aspect: 'square',
    width: 800,
    height: 800,
  },
  {
    src: 'https://images.unsplash.com/photo-1606577924006-27d39b132ae2?auto=format&fit=crop&w=800&q=80',
    alt: 'Warsztat MOTOBAJER — sklep z częściami',
    aspect: 'tall',
    width: 800,
    height: 1067,
  },
  {
    src: 'https://images.unsplash.com/photo-1600880292089-90a7e086ee0c?auto=format&fit=crop&w=800&q=80',
    alt: 'Warsztat MOTOBAJER — wymiana opon',
    aspect: 'wide',
    width: 800,
    height: 534,
  },
  {
    src: 'https://images.unsplash.com/photo-1565043666747-69f6646db940?auto=format&fit=crop&w=800&q=80',
    alt: 'Warsztat MOTOBAJER — narzędzia mechaniczne',
    aspect: 'square',
    width: 800,
    height: 800,
  },
  {
    src: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=800&q=80',
    alt: 'Warsztat MOTOBAJER — obsługa klienta',
    aspect: 'wide',
    width: 800,
    height: 534,
  },
  {
    src: 'https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&w=800&q=80',
    alt: 'Warsztat MOTOBAJER — fasada budynku',
    aspect: 'square',
    width: 800,
    height: 800,
  },
];

const aspectHeights: Record<string, string> = {
  tall: '280px',
  wide: '180px',
  square: '220px',
};
---

<section id="galeria" class="section-py below-fold bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="mb-10">
      <h2 class="reveal reveal-clip section-heading text-ink" style="font-family: var(--font-display);">
        Nasz warsztat
      </h2>
      <p class="reveal mt-2 text-sm" style="color: var(--color-ink-muted);">
        Nowoczesne wyposażenie i profesjonalne środowisko pracy.
      </p>
    </div>

    <style>
      @media (min-width: 640px) { .gallery-grid { columns: 3 !important; } }
      @media (min-width: 1024px) { .gallery-grid { columns: 4 !important; } }
    </style>

    <div class="gallery-grid" style="columns: 2; column-gap: 1rem;">
      {items.map((item, i) => (
        <figure
          class="gallery-item reveal mb-4 rounded-lg overflow-hidden break-inside-avoid"
          data-stagger={i * 60}
          style="display: inline-block; width: 100%;"
        >
          <img
            src={item.src}
            alt={item.alt}
            loading="lazy"
            decoding="async"
            class="w-full object-cover block"
            style={`height: ${aspectHeights[item.aspect]};`}
            width={item.width}
            height={item.aspect === 'tall' ? 1067 : item.aspect === 'wide' ? 534 : 800}
          />
        </figure>
      ))}
    </div>

  </div>
</section>
