---
import { Phone } from 'lucide-astro';

const links = [
  { href: '/#o-nas', label: 'O nas' },
  { href: '/#uslugi', label: 'Usługi' },
  { href: '/czesci', label: 'Części' },
  { href: '/#opinie', label: 'Opinie' },
  { href: '/faq', label: 'FAQ' },
  { href: '/kontakt', label: 'Kontakt' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string) {
  const hrefPath = href.split('#')[0].replace(/\/$/, '');
  if (!hrefPath) return false;
  return path === hrefPath || path.startsWith(hrefPath + '/');
}
---

<nav
  id="main-nav"
  aria-label="Nawigacja główna"
  class="fixed top-0 left-0 right-0 z-40 bg-navy transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <div aria-hidden="true" style="width: 4px; height: 1.6rem; background: var(--color-accent); border-radius: 1px; flex-shrink: 0;"></div>
      <span
        class="font-bold text-white"
        style="font-family: var(--font-display); letter-spacing: 0.07em; font-size: 1.35rem;"
      >
        MOTOBAJER
      </span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-7">
      {links.map((link) => (
        <a
          href={link.href}
          class={`nav-link-slide text-sm font-medium transition-colors duration-150 ${isActive(link.href) ? 'text-white' : 'text-white/70 hover:text-white'}`}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <a
        href="tel:+48609845865"
        class="ml-1 inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-semibold text-white transition-all duration-150 focus-ring-white"
        style="background: var(--color-accent);"
        onmouseover="this.style.background='var(--color-accent-hover)'"
        onmouseout="this.style.background='var(--color-accent)'"
      >
        <Phone class="w-4 h-4 shrink-0" aria-hidden="true" />
        Zadzwoń
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="hamburger"
      aria-label="Otwórz menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden flex flex-col justify-center items-center w-11 h-11 gap-1.5"
    >
      <span class="block w-6 h-0.5 bg-white transition-all duration-200 origin-center" id="ham-1"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-200" id="ham-2"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-200 origin-center" id="ham-3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-300 bg-navy-dark"
  >
    <div class="px-4 py-4 flex flex-col gap-1">
      {links.map((link) => (
        <a
          href={link.href}
          class={`mobile-nav-link py-2.5 px-3 rounded-md font-medium transition-colors ${isActive(link.href) ? 'text-white bg-white/10' : 'text-white/80 hover:text-white hover:bg-white/10'}`}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <a
        href="tel:+48609845865"
        class="mt-2 inline-flex items-center justify-center gap-2 py-3 px-3 rounded-md font-semibold text-white focus-ring-white"
        style="background: var(--color-accent);"
      >
        <Phone class="w-4 h-4 shrink-0" aria-hidden="true" />
        Zadzwoń: 609 845 865
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const ham1 = document.getElementById('ham-1')!;
  const ham2 = document.getElementById('ham-2')!;
  const ham3 = document.getElementById('ham-3')!;

  // Scroll state
  window.addEventListener('scroll', () => {
    nav.classList.toggle('nav-scrolled', window.scrollY > 90);
  }, { passive: true });

  // Hamburger toggle
  let open = false;
  hamburger.addEventListener('click', () => {
    open = !open;
    hamburger.setAttribute('aria-expanded', String(open));
    if (open) {
      mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
      ham1.style.transform = 'translateY(8px) rotate(45deg)';
      ham2.style.opacity = '0';
      ham3.style.transform = 'translateY(-8px) rotate(-45deg)';
    } else {
      mobileMenu.style.maxHeight = '0';
      ham1.style.transform = '';
      ham2.style.opacity = '';
      ham3.style.transform = '';
    }
  });

  // Close menu on nav link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      hamburger.setAttribute('aria-expanded', 'false');
      mobileMenu.style.maxHeight = '0';
      ham1.style.transform = '';
      ham2.style.opacity = '';
      ham3.style.transform = '';
    });
  });
</script>
