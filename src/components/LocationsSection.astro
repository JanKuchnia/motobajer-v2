---
const locations = [
  {
    name: 'Centrum Serwisowe',
    role: 'Warsztat & Adres Rejestrowy',
    address: 'ul. Drogowców 7',
    city: '32-400 Myślenice',
    mapQuery: 'Drogowców 7, Myślenice',
    tag: 'Główna siedziba',
  },
  {
    name: 'Sklep Auto-Części',
    role: 'Sprzedaż detaliczna',
    address: 'ul. Armii Krajowej 2',
    city: '32-400 Myślenice',
    mapQuery: 'Armii Krajowej 2, Myślenice',
    tag: 'Centrum miasta',
  },
];
---

<section id="lokalizacje" class="section-py below-fold bg-navy">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="mb-12 text-center">
      <h2
        class="reveal section-heading text-white"
        style="font-family: var(--font-display);"
      >
        Gdzie nas znajdziesz
      </h2>
      <p class="reveal mt-3 text-base" style="color: oklch(76% 0.04 265);">
        Dwa punkty obsługi w Myślenicach: warsztat i sklep z częściami.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {locations.map((loc, i) => (
        <div class="reveal flex flex-col gap-5" style={`transition-delay: ${i * 100}ms;`}>
          <!-- Info card -->
          <div
            class="rounded-xl p-6"
            style="background: oklch(100% 0 0 / 0.06); border: 1px solid oklch(100% 0 0 / 0.1);"
          >
            <div class="flex items-start justify-between gap-3 mb-3">
              <div>
                <p
                  class="text-lg font-bold text-white"
                  style="font-family: var(--font-display);"
                >
                  {loc.name}
                </p>
                <p class="text-sm mt-0.5" style="color: oklch(68% 0.05 265);">{loc.role}</p>
              </div>
              <span
                class="text-xs font-semibold px-2.5 py-1 rounded-full shrink-0"
                style="background: oklch(100% 0 0 / 0.1); color: oklch(82% 0.06 265);"
              >
                {loc.tag}
              </span>
            </div>

            <div class="flex items-start gap-2 text-sm" style="color: oklch(82% 0.03 265);">
              <svg
                aria-hidden="true"
                class="w-4 h-4 mt-0.5 shrink-0"
                style="color: oklch(68% 0.08 265);"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
              </svg>
              <span>{loc.address}, {loc.city}</span>
            </div>
          </div>

          <!-- Map embed -->
          <div class="rounded-xl overflow-hidden" style="height: 280px;">
            <iframe
              title={`Mapa lokalizacji: ${loc.name}`}
              width="100%"
              height="280"
              style="border: 0; display: block;"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              src={`https://maps.google.com/maps?q=${encodeURIComponent(loc.mapQuery)}&output=embed&z=16`}
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
