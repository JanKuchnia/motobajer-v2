---
import { services } from '../data/services';
import { ArrowRight, Phone } from 'lucide-astro';

const icons: Record<string, string> = {
  wrench: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.654-4.654m5.896-3.046.206-.2A9.5 9.5 0 0 0 7.5 3.5c-.977 0-1.915.145-2.796.413m5.716 9.257L7.5 7.5m6.136 5.67A9.458 9.458 0 0 1 7.5 14.5c-.977 0-1.915-.145-2.796-.413"/>`,
  cpu: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z"/>`,
  disc: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z"/>`,
  snowflake: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 12h18M5.636 5.636l12.728 12.728M18.364 5.636 5.636 18.364"/><circle cx="12" cy="12" r="2.25" fill="currentColor" stroke="none"/>`,
  bolt: `<path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/>`,
  wheel: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3c4.97 0 9 4.03 9 9s-4.03 9-9 9-9-4.03-9-9 4.03-9 9-9Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v3.75m0 0 2.25 2.25M12 12l-2.25 2.25M12 12l2.25-2.25M12 12l-2.25-2.25"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>`,
};
---

<section id="uslugi" class="section-py below-fold" style="background: var(--color-surface-1);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Heading -->
    <div class="mb-8">
      <h2 class="reveal reveal-clip section-heading text-ink" style="font-family: var(--font-display);">
        Co naprawiamy
      </h2>
      <p class="reveal mt-3 text-base max-w-lg" style="color: var(--color-ink-muted);">
        Kompleksowa obsługa samochodów osobowych i dostawczych pod jednym dachem.
      </p>
    </div>

    <!-- Services list -->
    <div class="border-t-2" style="border-color: var(--color-ink);">
      {services.map((service, i) => (
        <div
          class="reveal service-row border-b"
          style={`border-color: oklch(86% 0.01 265); padding: 1.625rem 0;`}
          data-stagger={i * 55}
        >
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8">
            <!-- Icon + title -->
            <div class="flex items-center gap-4 shrink-0" style="width: min(100%, 21rem);">
              <div
                class="service-icon w-10 h-10 rounded flex items-center justify-center shrink-0"
                style="background: var(--color-accent); color: #fff;"
              >
                <svg
                  aria-hidden="true"
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  viewBox="0 0 24 24"
                  set:html={icons[service.icon]}
                />
              </div>
              <h3
                class="font-bold text-ink"
                style="font-family: var(--font-display); font-size: clamp(1.3rem, 2.6vw, 1.8rem); letter-spacing: 0.02em; line-height: 1.15;"
              >
                {service.title}
              </h3>
            </div>
            <!-- Description + link -->
            <div class="flex-1 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6">
              <p class="text-sm leading-relaxed flex-1" style="color: var(--color-ink-muted);">
                {service.description}
              </p>
              <a
                href={`/uslugi/${service.slug}`}
                class="inline-flex items-center gap-1.5 text-sm font-semibold whitespace-nowrap shrink-0 transition-colors hover-text-navy-light"
                style="color: var(--color-navy);"
              >
                Dowiedz się więcej
                <ArrowRight class="w-3.5 h-3.5 shrink-0" aria-hidden="true" />
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="reveal mt-12 pt-10 border-t flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"
      style="border-color: oklch(88% 0.01 265);">
      <p class="text-sm" style="color: var(--color-ink-muted);">
        Nie jesteś pewien, co Twój samochód potrzebuje?
      </p>
      <a
        href="tel:+48609845865"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-navy hover:text-navy-light transition-colors"
      >
        <Phone class="w-4 h-4 shrink-0" aria-hidden="true" />
        Zadzwoń, doradzimy bezpłatnie
      </a>
    </div>
  </div>
</section>
